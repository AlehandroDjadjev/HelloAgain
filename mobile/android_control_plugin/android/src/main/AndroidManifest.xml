<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Permissions ─────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!--
        specialUse foreground service type requires this permission on Android 14+.
        The service is used to display active automation state to the user at all times.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!--
        Package visibility: explicit allowlist only.
        DO NOT add QUERY_ALL_PACKAGES — only the supported app set is declared.
    -->
    <queries>
        <package android:name="com.whatsapp" />
        <package android:name="com.google.android.apps.maps" />
        <package android:name="com.android.chrome" />
        <package android:name="com.google.android.gm" />
        <package android:name="com.supercell.brawlstars" />
    </queries>

    <application>

        <!-- ── AccessibilityService ──────────────────────────────────────── -->
        <service
            android:name="com.example.control.service.AutomationAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/automation_accessibility_config" />
        </service>

        <!-- ── Foreground session service ────────────────────────────────── -->
        <!--
            Keeps a persistent notification visible whenever an automation session
            is active so the user can always see and stop it.
            foregroundServiceType="specialUse" — required for Android 14+.
        -->
        <service
            android:name="com.example.control.service.AutomationForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Automation agent controlling Android apps on behalf of the user. Visible to the user at all times." />
        </service>

    </application>

</manifest>
